<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.RC4" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Main colors for a "comfy" dark mode -->
        <item name="colorPrimary">#BB86FC</item>
        <item name="colorPrimaryVariant">#3700B3</item>
        <item name="colorOnPrimary">#000000</item>

        <item name="colorSecondary">#03DAC6</item>
        <item name="colorOnSecondary">#000000</item>

        <!-- Deep dark backgrounds for comfort -->
        <item name="android:windowBackground">#121212</item>
        <item name="android:colorBackground">#121212</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">#E1E1E1</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">#E1E1E1</item>
        <item name="android:textColorSecondary">#B0B0B0</item>

        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <style name="Theme.RC4" parent="Base.Theme.RC4" />
</resources>